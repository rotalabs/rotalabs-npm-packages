{
  "name": "@rotalabs/context",
  "version": "1.0.1",
  "description": "Context intelligence for AI agents - Ingest, search, and subscribe to shared context",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "context",
    "ai-agents",
    "rag",
    "embeddings",
    "semantic-search",
    "context-engine",
    "rotalabs"
  ],
  "author": "Rotalabs <dev@rotalabs.ai>",
  "license": "Apache-2.0",
  "homepage": "https://rotalabs.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rotalabs/rotalabs-npm-packages.git",
    "directory": "context"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "sideEffects": false
}
